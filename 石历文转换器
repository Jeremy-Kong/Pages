                svg: '<svg viewBox="0 0 100 100"><line x1="30" y1="28" x2="70" y2="28" stroke="#c9a961" stroke-width="3"/><line x1="30" y1="50" x2="70" y2="50" stroke="#c9a961" stroke-width="4"/><line x1="30" y1="72" x2="70" y2="72" stroke="#c9a961" stroke-width="3"/></svg>' }
        };
        
        // 复合规则
        const compounds = {
            '日月': { name: '明', meaning: '光明、明亮' },
            '水木': { name: '沐', meaning: '沐浴、润泽' },
            '人山': { name: '仙', meaning: '仙人、超凡' },
            '木木': { name: '林', meaning: '树林、众多' }
        };
        
        function convertText() {
            const input = document.getElementById('inputText').value.trim();
            const grid = document.getElementById('glyphGrid');
            const stats = document.getElementById('glyphStats');
            const sacredMode = document.getElementById('sacredMode').checked;
            const showTooltip = document.getElementById('showTooltip').checked;
            
            if (!input) {
                alert('请输入文字');
                return;
            }
            
            grid.innerHTML = '';
            document.getElementById('infoPanel').classList.remove('active');
            
            let result = [];
            let i = 0;
            
            // 解析复合词
            while (i < input.length) {
                let matched = false;
                
                // 跳过空格
                if (input[i] === ' ') {
                    i++;
                    continue;
                }
                
                // 尝试匹配2字复合
                if (i < input.length - 1) {
                    const pair = input[i] + input[i+1];
                    if (compounds[pair] && glyphs[input[i]] && glyphs[input[i+1]]) {
                        result.push({
                            type: 'compound',
                            chars: pair,
                            data: compounds[pair],
                            glyphs: [glyphs[input[i]], glyphs[input[i+1]]]
                        });
                        i += 2;
                        matched = true;
                        continue;
                    }
                }
                
                // 单字匹配
                if (glyphs[input[i]]) {
                    result.push({
                        type: 'single',
                        char: input[i],
                        data: glyphs[input[i]]
                    });
                } else {
                    result.push({
                        type: 'unknown',
                        char: input[i],
                        data: { name: input[i], meaning: '未定义字符', svg: '<svg viewBox="0 0 100 100"><rect x="30" y="30" width="40" height="40" fill="none" stroke="#5a5040" stroke-width="2" stroke-dasharray="4"/><text x="50" y="55" text-anchor="middle" fill="#5a5040" font-size="20">?</text></svg>' }
                    });
                }
                i++;
            }
            
            stats.textContent = `共 ${result.length} 个符号（${result.filter(r => r.type !== 'unknown').length} 个已识别）`;
            
            // 渲染
            result.forEach((item, index) => {
                const block = document.createElement('div');
                block.className = 'glyph-block';
                
                if (item.type === 'compound') {
                    if (sacredMode && (item.glyphs[0].sacred || item.glyphs[1].sacred)) {
                        block.classList.add('sacred');
                    }
                    block.innerHTML = `
                        <div class="glyph-svg" style="display: flex; flex-direction: column; gap: 5px;">
                            <div style="flex: 1;">${item.glyphs[0].svg}</div>
                            <div style="flex: 1;">${item.glyphs[1].svg}</div>
                        </div>
                        ${showTooltip ? `<div class="glyph-tooltip">${item.data.name}: ${item.data.meaning}</div>` : ''}
                    `;
                    block.onclick = () => showInfo(item.data.name, item.data.meaning, 'compound');
                } else {
                    if (sacredMode && item.data.sacred) block.classList.add('sacred');
                    block.innerHTML = `
                        <div class="glyph-svg">${item.data.svg}</div>
                        ${showTooltip ? `<div class="glyph-tooltip">${item.data.name}</div>` : ''}
                    `;
                    block.onclick = () => showInfo(item.data.name, item.data.meaning, item.data.type);
                }
                
                block.style.animation = `fadeIn 0.5s ease ${index * 0.05}s both`;
                grid.appendChild(block);
            });
        }
        
        function showInfo(name, meaning, type) {
            const panel = document.getElementById('infoPanel');
            const title = document.getElementById('infoTitle');
            const content = document.getElementById('infoContent');
            
            const typeNames = {
                'celestial': '天体类', 'nature': '自然类', 'human': '人类类',
                'abstract': '抽象类', 'animal': '动物类', 'number': '数字类',
                'compound': '组合字', 'unknown': '未知'
            };
            
            title.textContent = `◆ ${name} ◆`;
            content.innerHTML = `
                <p><strong>含义：</strong>${meaning}</p>
                <p><strong>类别：</strong>${typeNames[type] || type}</p>
            `;
            panel.classList.add('active');
        }
        
        function clearText() {
            document.getElementById('inputText').value = '';
            document.getElementById('glyphGrid').innerHTML = '<div class="empty-state">等待输入...</div>';
            document.getElementById('glyphStats').textContent = '';
            document.getElementById('infoPanel').classList.remove('active');
        }
        
        function exportResult() {
            alert('提示：\n\n1. PC端：按 F11 全屏后截图，或右键"打印"保存为PDF\n2. 手机端：直接截图保存\n\n所有字符均为高清矢量图形，可任意放大打印。');
        }
        
        // 初始化
        window.onload = () => convertText();
    </script>
