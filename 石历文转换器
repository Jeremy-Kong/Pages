                svg: '<svg viewBox="0 0 100 100"><line x1="30" y1="38" x2="70" y2="38" stroke="#c9a961" stroke-width="4" stroke-linecap="round"/><line x1="30" y1="62" x2="70" y2="62" stroke="#c9a961" stroke-width="4" stroke-linecap="round"/></svg>' },
            
